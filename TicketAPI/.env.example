# ⚙️ Variáveis de Ambiente - Exemplos
# Copie este arquivo para .env e customize conforme necessário
# IMPORTANTE: NÃO versione arquivos .env com credenciais reais no Git!

# ========================================
# CONFIGURAÇÃO DO ASP.NET CORE
# ========================================

# Ambiente: Development, Staging, Production
ASPNETCORE_ENVIRONMENT=Development

# URLs de binding da aplicação
ASPNETCORE_URLS=http://+:5000

# ========================================
# BANCO DE DADOS - SQL SERVER
# ========================================

# Opção 1: SQL Server LocalDB (DESENVOLVIMENTO)
# Padrão em appsettings.json
ConnectionStrings__DefaultConnection=Server=(localdb)\mssqllocaldb;Database=TicketAPI;Trusted_Connection=true;MultipleActiveResultSets=true;

# Opção 2: SQL Server Express/Standard (DESENVOLVIMENTO)
# ConnectionStrings__DefaultConnection=Server=localhost;Database=TicketAPI;User Id=sa;Password=YourPassword123!;

# Opção 3: SQL Server em Docker (PRODUÇÃO)
# ConnectionStrings__DefaultConnection=Server=ticketapi-db,1433;Database=TicketAPI;User Id=sa;Password=SecurePassword123!;Encrypt=False;

# Opção 4: Azure SQL Database (PRODUÇÃO CLOUD)
# ConnectionStrings__DefaultConnection=Server=your-server.database.windows.net;Database=TicketAPI;User Id=your-user@server;Password=SecurePassword123!;Encrypt=true;Connection Timeout=30;

# ========================================
# LOGGING
# ========================================

# Nível padrão: Trace, Debug, Information, Warning, Error, Critical
Logging__LogLevel__Default=Information

# Logging específico para Entity Framework Core
Logging__LogLevel__Microsoft.EntityFrameworkCore=Debug

# Logging para Hot Chocolate
Logging__LogLevel__HotChocolate=Information

# ========================================
# GRAPHQL - HOT CHOCOLATE
# ========================================

# Modo de introspeção (permitir schema queries)
GraphQL__Introspection__Enabled=true

# Modo de desenvolvimento (mensagens de erro detalhadas)
GraphQL__Development__Enabled=true

# ========================================
# CORS (Cross-Origin Resource Sharing)
# ========================================

# Origens permitidas (separadas por ponto-vírgula)
# DESENVOLVIMENTO
CORS__AllowedOrigins=http://localhost:3000;http://localhost:3001;http://localhost:5000

# PRODUÇÃO
# CORS__AllowedOrigins=https://seu-dominio.com;https://www.seu-dominio.com

# ========================================
# AUTENTICAÇÃO (Futuro)
# ========================================

# Auth0 (se implementar)
# Auth0__Domain=seu-tenant.auth0.com
# Auth0__ClientId=seu-client-id
# Auth0__ClientSecret=seu-client-secret

# JWT
# JWT__SecretKey=sua-chave-secreta-muito-longa-aqui
# JWT__Issuer=https://seu-dominio.com
# JWT__Audience=https://seu-dominio.com/api

# ========================================
# CACHE DISTRIBUÍDO (Futuro)
# ========================================

# Redis
# Redis__ConnectionString=localhost:6379
# Redis__Db=0

# ========================================
# SERVIÇOS EXTERNOS (Futuro)
# ========================================

# Email (SendGrid, Mailgun, etc)
# Email__Provider=SendGrid
# Email__ApiKey=seu-api-key

# SMS (Twilio, AWS SNS, etc)
# SMS__Provider=Twilio
# SMS__ApiKey=seu-api-key
# SMS__AccountSid=seu-account-sid

# Webhooks
# Webhooks__NotificationUrl=https://seu-servico.com/webhook/tickets

# ========================================
# MONITORAMENTO E OBSERVABILIDADE
# ========================================

# Application Insights (Azure Monitor)
# ApplicationInsights__InstrumentationKey=sua-key-aqui

# Serilog
# Serilog__MinimumLevel=Information

# ========================================
# RATE LIMITING (Futuro)
# ========================================

# RateLimit__Enabled=true
# RateLimit__RequestsPerMinute=60

# ========================================
# DOCKER COMPOSE
# ========================================

# Quando usar docker-compose, estas variáveis são herdadas
# Veja docker-compose.yml para valores

# Nota: No docker-compose.yml, use ${VARIABLE_NAME} para referenciar

# ========================================
# NOTAS DE SEGURANÇA
# ========================================

# ⚠️ NUNCA versione arquivo .env com credenciais reais
# ✅ Use .env apenas localmente
# ✅ Use secrets management em produção (Azure Key Vault, AWS Secrets Manager)
# ✅ Para CI/CD, use secrets do GitHub Actions/Azure DevOps

# ========================================
# EXEMPLO DE USO
# ========================================

# 1. Copie este arquivo:
#    cp .env.example .env

# 2. Customize com seus valores

# 3. No desenvolvimento, o .env é carregado automaticamente pelo:
#    - Docker Compose
#    - dotnet user-secrets (opcional)
#    - Variáveis de sistema

# 4. Ignore em Git:
#    .env (já está em .gitignore)

# ========================================
# DESENVOLVIMENTO vs PRODUÇÃO
# ========================================

# DESENVOLVIMENTO:
# - Introspection: habilitado
# - Debug: habilitado
# - CORS: liberado para localhost
# - Logging: Debug
# - BD: LocalDB

# PRODUÇÃO:
# - Introspection: desabilitado (segurança)
# - Debug: desabilitado
# - CORS: apenas domínios específicos
# - Logging: Warning
# - BD: SQL Server gerenciado
# - Secrets: Azure Key Vault

# ========================================
